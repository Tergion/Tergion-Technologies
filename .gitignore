# env files (can opt-in for committing if needed)
.env*
!.env.example
.dev.vars*
!.dev.vars.example

# cloudflare
.open-next/
.wrangler/
cloudflare-env.d.ts

# typescript
*.tsbuildinfo
next-env.d.ts
